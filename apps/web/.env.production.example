# Production environment variables for the Vercel (fra1) deployment.
# Copy the values into Vercel's per-environment env settings — NEVER commit real
# secrets or a real .env to the repo. Every value below is a placeholder.
# See docs/operations/infrastructure-plan.md for provisioning order (owner Gate 1).

# Neon production connection string (Frankfurt). Read by getDatabase().
DATABASE_URL="postgres://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/DBNAME?sslmode=require"

# Canonical server-side origin used for email links — never derived from request headers.
APP_PUBLIC_ORIGIN="https://your-app.vercel.app"

# Client-side origin (exposed to the browser bundle).
NEXT_PUBLIC_APP_ORIGIN="https://your-app.vercel.app"

# Runtime environment. Vercel sets this to "production" automatically; pin it for clarity.
NODE_ENV="production"

# Keep transactional email delivery OFF until the Gmail OAuth secrets below are set and tested.
EMAIL_DELIVERY_ENABLED="false"

# Owner-approved private-beta provider. The adapter fails closed unless every
# required Gmail value is present. Put real values in Vercel only, never here.
EMAIL_DELIVERY_PROVIDER="gmail"
GMAIL_CLIENT_ID="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"
GMAIL_CLIENT_SECRET="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET"
GMAIL_REFRESH_TOKEN="REPLACE_WITH_OWNER_AUTHORIZED_REFRESH_TOKEN"
GMAIL_SENDER_EMAIL="support@keepitup.social"
GMAIL_SENDER_NAME="KeepItUp"
GMAIL_REPLY_TO="support@keepitup.social"

# Upstash Redis (Frankfurt) — shared rate-limit store for Gate 6. Adapter falls
# back to in-memory until both are set.
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_WITH_UPSTASH_REST_TOKEN"

# Sentry error monitoring (EU data region). All four are OPTIONAL: with none
# set, Sentry.init is a no-op and the app behaves exactly as it does today.
#
# Public DSN — read by server, edge, AND client Sentry.init (it is public-safe
# and must be NEXT_PUBLIC_ so the browser bundle can send client errors).
# NEXT_PUBLIC_SENTRY_DSN="https://PUBLIC_KEY@oXXXX.ingest.de.sentry.io/PROJECT_ID"
#
# Org/project slugs — used by the build plugin only. Needed for source-map upload.
# SENTRY_ORG="your-sentry-org"
# SENTRY_PROJECT="your-sentry-project"
#
# Build-time secret for source-map upload. When ABSENT (the default), the build
# plugin skips upload entirely — no error. NEVER commit a real token; set it in
# Vercel's build env (and CI) only. Source maps need SENTRY_ORG+SENTRY_PROJECT too.
# SENTRY_AUTH_TOKEN="REPLACE_WITH_SENTRY_AUTH_TOKEN"

# Sport Date Plus billing (Stripe, €6.99/mo). All four are OPTIONAL and the app
# FAILS CLOSED when any is absent (the default): Plus is simply unavailable
# ("coming soon"), no member is charged, and nothing core is affected. Add only
# TEST keys during the test-mode phase; LIVE keys + flipping the flag are
# OWNER-ONLY go-live steps (docs/operations/monetization-go-live-runbook.md).
# NEVER commit a real key/secret/price id — set these in Vercel env only.
# STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_STRIPE_TEST_SECRET_KEY"
# STRIPE_PRICE_ID="price_REPLACE_WITH_6_99_MONTHLY_PRICE_ID"
# STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_WEBHOOK_SIGNING_SECRET"
# Master switch — leave OFF (unset or "false") until the owner flips it at go-live.
# BILLING_ENABLED="false"

# Shared secret for the protected Vercel Cron session-cleanup endpoint.
# The endpoint fails closed (refuses to run) when this is unset. Use a long random value.
CRON_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"

# RUN_DB_INTEGRATION is test-only and must NEVER be set in production.
